<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="traffic_light">
    <static>false</static>

    <link name="pole">
      <pose>0 0 0.07 0 0 0</pose>
      <gravity>false</gravity>
      <visual name="v">
        <geometry><cylinder><radius>0.01</radius><length>0.14</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient></material>
      </visual>
    </link>

    <link name="head">
      <pose>0 0 0.17 0 0 0</pose>
      <gravity>false</gravity>
      <visual name="v">
        <geometry><box><size>0.05 0.05 0.06</size></box></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient></material>
      </visual>
    </link>

    <link name="red_light">
      <pose>0.025 0 0.185 0 0 0</pose>
      <gravity>false</gravity>
      <visual name="v">
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material><ambient>1 0 0 1</ambient><emissive>1 0 0 1</emissive></material>
      </visual>
    </link>

    <link name="green_light">
      <pose>0.025 0 0.155 0 0 0</pose>
      <gravity>false</gravity>
      <visual name="v">
        <geometry><sphere><radius>0.012</radius></sphere></geometry>
        <material><ambient>0 1 0 1</ambient><emissive>0 1 0 1</emissive></material>
      </visual>
    </link>

    <link name="mask">
      <pose>0.035 0 0.17 0 0 0</pose>
      <gravity>false</gravity>
      <inertial>
        <mass>0.1</mass> <inertia>
          <ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="v">
        <geometry><box><size>0.005 0.045 0.035</size></box></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient></material>
      </visual>
    </link>

    <joint name="pole_to_head" type="fixed"><parent>pole</parent><child>head</child></joint>
    <joint name="r_fix" type="fixed"><parent>head</parent><child>red_light</child></joint>
    <joint name="g_fix" type="fixed"><parent>head</parent><child>green_light</child></joint>

    <joint name="mask_joint" type="prismatic">
      <parent>head</parent>
      <child>mask</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-0.015</lower><upper>0.015</upper></limit>
        <dynamics><damping>50.0</damping></dynamics>
      </axis>
    </joint>

    <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
      <joint_name>mask_joint</joint_name>
      <topic>/traffic_light/cmd_pos</topic>
      <p_gain>2500.0</p_gain>
      <d_gain>10.0</d_gain>
    </plugin>
  </model>
</sdf>
